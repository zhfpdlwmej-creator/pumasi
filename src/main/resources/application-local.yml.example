# 이 파일을 application-local.yml 로 복사한 뒤 실제 값으로 채워서 쓰세요.
# application-local.yml 은 .gitignore 에 등록되어 있어 커밋되지 않습니다.
#
# Supabase Session pooler 사용 예시 (무료 플랜은 직접 연결이 IPv6 전용이라 PC에서 안 닿음).
# Project Settings → Database → Connection string → URI → "Session" mode 에서 복사.

spring:
  datasource:
    url: jdbc:postgresql://aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres
    username: postgres.YOUR_PROJECT_REF
    password: YOUR_DB_PASSWORD

# 카카오 키 — javascript-key는 공유 SDK용(노출 허용), rest-api-key는 OAuth 로그인용(절대 비공개)
# client-secret 은 Kakao Developers → 보안 → Client Secret 이 "사용함" 인 경우에만 채움
app:
  kakao:
    javascript-key: YOUR_KAKAO_JS_KEY
    rest-api-key: YOUR_KAKAO_REST_API_KEY
    redirect-uri: http://localhost:8181/auth/kakao/callback
    client-secret: YOUR_KAKAO_CLIENT_SECRET_OR_LEAVE_EMPTY
